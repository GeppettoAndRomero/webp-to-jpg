{
  "name": "WebP to JPG \u2014 runlocally",
  "short_name": "WebP to JPG",
  "description": "Convert WebP images to JPG or PNG in your browser. Nothing is uploaded. Works offline.",
  "start_url": "/webp-to-jpg/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "background_color": "#ffffff",
  "theme_color": "#6366f1",
  "scope": "/webp-to-jpg/",
  "icons": [
    {
      "src": "/webp-to-jpg/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/webp-to-jpg/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": [
    "photo",
    "utilities",
    "productivity"
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "focus-existing"
  }
}
